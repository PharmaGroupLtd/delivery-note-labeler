<Window x:Class="DeliveryNoteLabeler.UpdateAvailableWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Update available"
        Height="360"
        Width="520"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <DockPanel LastChildFill="True">
        <Border DockPanel.Dock="Bottom"
                Background="{StaticResource PanelBackgroundBrush}"
                BorderBrush="{StaticResource BorderBrushStandard}"
                BorderThickness="0,1,0,0"
                Padding="12,10">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Content="Skip this version"
                        Style="{StaticResource StandardButton}"
                        MinWidth="112"
                        Margin="0,0,8,0"
                        Click="Skip_Click" />
                <Button Content="Later"
                        Style="{StaticResource StandardButton}"
                        MinWidth="88"
                        Margin="0,0,8,0"
                        IsCancel="True" />
                <Button Content="Download update"
                        Style="{StaticResource PrimaryButton}"
                        MinWidth="120"
                        IsDefault="True"
                        Click="Download_Click" />
            </StackPanel>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="16">
                <TextBlock Text="A new version is available"
                           Style="{StaticResource SectionHeaderText}" />
                <TextBlock x:Name="VersionSummaryLabel"
                           Margin="0,8,0,12"
                           TextWrapping="Wrap"
                           Style="{StaticResource CaptionText}" />
                <TextBlock Text="What's new"
                           Style="{StaticResource SectionHeaderText}" />
                <TextBlock x:Name="ReleaseNotesLabel"
                           Margin="0,8,0,0"
                           TextWrapping="Wrap"
                           Style="{StaticResource CaptionText}" />
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
